<%- include('partials/header') %>
<h1 class="font-bold text-4xl">Bem-vindo, User!</h1>
<p>Aqui está o resumo da sua barbearia</p>
<section id="sectionResumo" class="flex flex-col gap-y-5 justify-center pt-5">
    <div class="bg-white w-full h-32 shadow-lg rounded-lg flex items-center p-5">
        <div>
            <div class="bg-blue-800/15 w-20 h-20 rounded-[100%] flex justify-center items-center">
                <img src="assets/images/peopleSectionResumo.svg" alt="Icone de varias pessoas" width="60" height="60">
            </div>
        </div>
        <div class="pl-6">
            <h2 id="counterClients" class="font-bold text-3xl"></h2>
            <p class="text-xl">Clientes</p>
        </div>
    </div>
    <div class="bg-white w-full h-32 shadow-lg rounded-lg flex items-center p-5">
        <div>
            <div class="bg-green-400/15 w-20 h-20 rounded-[100%] flex justify-center items-center">
                <img src="assets/images/dateSectionResume.svg" alt="icone de uma agenda" width="60" height="60">
            </div>
        </div>
        <div class="pl-6">
            <h2 class="font-bold text-3xl">99</h2>
            <p class="text-xl">Agendamentos Hoje</p>
        </div>
    </div>
    <button id="buttonSeeMore" class="cursor-pointer relative z-0 bottom-30 h-36 w-full pt-20 bg-linear-to-t from-zinc-100 from-40% to-blue-500/0">
        Ver Mais
    </button>
    <div id="contentSeeMore" class="hidden">
        <div class="bg-white w-full h-32 shadow-lg rounded-lg flex items-center p-5 mb-5">
            <div>
                <div class="bg-orange-600/15 w-20 h-20 rounded-[100%] flex justify-center items-center">
                    <img src="assets/images/moneySectionResume.svg" alt="icone de dinheiro" width="60" height="60">
                </div>
            </div>
            <div class="pl-6">
                <h2 class="font-bold text-3xl">99</h2>
                <p class="text-xl">Faturamento Hoje</p>
            </div>
        </div>
        <div class="bg-white w-full h-32 shadow-lg rounded-lg flex items-center p-5">
            <div>
                <div class="bg-purple-600/15 w-20 h-20 rounded-[100%] flex justify-center items-center">
                    <img src="assets/images/personSectionResume.svg" alt="icone de uma pessoa" width="60" height="60">
                </div>
            </div>
            <div class="pl-6">
                <h2 class="font-bold text-3xl">99</h2>
                <p class="text-xl">Funcionarios</p>
            </div>
        </div>
    </div>
    <button id="buttonSeeLess" class="hidden cursor-pointer relative z-0 bottom-8 h-14 pt-5 w-full bg-linear-to-t from-zinc-100 from-70% to-blue-500/0">
        Ver Menos
    </button>
</section>
<script src="/js/index.js" defer></script>
<%- include('partials/footer') %>